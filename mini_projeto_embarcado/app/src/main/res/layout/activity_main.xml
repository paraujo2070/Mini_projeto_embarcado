<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32.dp"
        android:text="GENIUS RPI5"
        android:textColor="#333333"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8.dp"
        android:text="PRESSIONE START"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <FrameLayout
        android:id="@+id/geniusContainer"
        android:layout_width="320.dp"
        android:layout_height="320.dp"
        android:background="@drawable/genius_bg"
        app:layout_constraintBottom_toTopOf="@id/tvScore"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvStatus">

        <!-- UP - GREEN -->
        <View
            android:id="@+id/viewGreen"
            android:layout_width="100.dp"
            android:layout_height="100.dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="10.dp"
            android:background="@drawable/btn_green"
            android:alpha="0.3" />

        <!-- DOWN - YELLOW -->
        <View
            android:id="@+id/viewYellow"
            android:layout_width="100.dp"
            android:layout_height="100.dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="10.dp"
            android:background="@drawable/btn_yellow"
            android:alpha="0.3" />

        <!-- LEFT - RED -->
        <View
            android:id="@+id/viewRed"
            android:layout_width="100.dp"
            android:layout_height="100.dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="10.dp"
            android:background="@drawable/btn_red"
            android:alpha="0.3" />

        <!-- RIGHT - BLUE -->
        <View
            android:id="@+id/viewBlue"
            android:layout_width="100.dp"
            android:layout_height="100.dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="10.dp"
            android:background="@drawable/btn_blue"
            android:alpha="0.3" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="80.dp"
            android:layout_height="80.dp"
            android:layout_gravity="center"
            android:background="@drawable/btn_center"
            android:text="START"
            android:textSize="12sp"
            android:textColor="#FFFFFF" />

    </FrameLayout>

    <TextView
        android:id="@+id/tvScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48.dp"
        android:text="Pontuação: 0"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
